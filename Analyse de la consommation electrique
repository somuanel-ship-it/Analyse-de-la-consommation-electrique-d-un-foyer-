        "# --- ÉTAPE 1 : IMPORTER LES BIBLIOTHÈQUES ---\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.linear_model import LinearRegression\n",
        "\n",
        "# --- ÉTAPE 2 : CRÉER UN DATASET SIMPLE ---\n",
        "# Données : Mois, Température (°C), Consommation (kWh)\n",
        "data = {\n",
        "    \"Mois\": [1, 2, 3, 4, 5],\n",
        "        \"Température\": [18, 20, 22, 24, 26],\n",
        "            \"Consommation\": [500, 450, 400, 350, 300]\n",
        "            }\n",
        "            df = pd.DataFrame(data)\n",
        "            print(\"Dataset :\")\n",
        "            print(df)\n",
        "\n",
        "            # --- ÉTAPE 3 : AFFICHER LES STATISTIQUES ---\n",
        "            print(\"\\nStatistiques :\")\n",
        "            print(df.describe())\n",
        "\n",
        "            # --- ÉTAPE 4 : CRÉER UN GRAPHIQUE ---\n",
        "            plt.plot(df[\"Température\"], df[\"Consommation\"], marker='o')\n",
        "            plt.xlabel(\"Température (°C)\")\n",
        "            plt.ylabel(\"Consommation (kWh)\")\n",
        "            plt.title(\"Consommation vs Température\")\n",
        "            plt.grid(True)\n",
        "            plt.show()\n",
        "\n",
        "            # --- ÉTAPE 5 : RÉGRESSION LINÉAIRE ---\n",
        "            X = df[[\"Température\"]]  # Variable explicative (température)\n",
        "            y = df[\"Consommation\"]   # Variable à prédire (consommation)\n",
        "\n",
        "            model = LinearRegression()\n",
        "            model.fit(X, y)\n",
        "\n",
        "            # Afficher l'équation : Consommation = a * Température + b\n",
        "            a = model.coef_[0]\n",
        "            b = model.intercept_\n",
        "            print(f\"\\nÉquation de régression : Consommation = {a:.2f} * Température + {b:.2f}\")\n",
        "\n",
